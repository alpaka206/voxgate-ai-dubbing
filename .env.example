AUTH_SECRET=replace-with-a-long-random-string
AUTH_GOOGLE_ID=replace-with-google-client-id
AUTH_GOOGLE_SECRET=replace-with-google-client-secret
TURSO_DATABASE_URL=libsql://your-database-name.turso.io
TURSO_AUTH_TOKEN=replace-with-turso-auth-token
BLOB_READ_WRITE_TOKEN=vercel_blob_rw_xxx
ELEVENLABS_API_KEY=replace-with-elevenlabs-api-key
ELEVENLABS_MODEL_ID=eleven_multilingual_v2
ELEVENLABS_STT_MODEL_ID=scribe_v2
GEMINI_API_KEY=replace-with-gemini-api-key
GEMINI_MODEL=gemini-2.5-flash-lite
# No extra env vars are needed for the client-side 60-second crop flow, timing-fit tuning, final mix loudness handling, or resilient Gemini JSON parsing.
